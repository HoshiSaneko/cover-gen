# =================================================================
# cover-gen 配置文件 (.env)
# 复制此文件为 .env 并填入你的 API Key
# =================================================================

# --- 核心配置 ---

# 聊天模型提供商 (用于分析文章内容)
# 可选值: qwen (通义千问) | gemini (Google Gemini)
CHAT_PROVIDER=qwen

# 生图模型提供商 (用于生成封面图)
IMAGE_PROVIDER=qwen

# --- API 密钥 ---

# 阿里云 DashScope API Key (如果使用 qwen)
# 获取地址: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio API Key (如果使用 gemini)
# 获取地址: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- 模型配置 (可选，通常使用默认即可) ---

# --- 风格与生成参数 ---

# 默认风格预设
# 可选值: flat (扁平), minimal (极简), tech_abstract (科技), isometric (2.5D), etc.
# 更多风格请查看 src/styles.py
DEFAULT_STYLE=isometric

# 内容主体占比 (0.1 - 0.9)
# 数值越大，主体物体在画面中越大
CONTENT_RATIO=0.6

# 是否自动适配深色模式 (true/false)
# 如果为 true，会根据文章内容判断是否适合深色背景
DARK_MODE_ADAPTIVE=true

# 强制指定背景色 (Hex 颜色代码，如 #1a1a1a)
# 留空则由 AI 自动决定
BACKGROUND_COLOR=

# 额外提示词 (会追加在 AI 生成的提示词之后)
# EXTRA_PROMPT=4k resolution, highly detailed

# 禁止的提示词 (不希望出现在画面中的内容，逗号或空格分隔)
# 生成提示词时会让 LLM 避免在描述中出现这些内容
# NEGATIVE_PROMPT=text, watermark, low quality, blurry, distorted, ugly, bad anatomy

# --- 输出设置 ---

# 是否启用图片压缩 (true/false)
# true: 输出 JPG (较小) | false: 输出 PNG (无损)
ENABLE_COMPRESSION=true

# JPG 压缩质量 (1-100)
JPG_QUALITY=85
